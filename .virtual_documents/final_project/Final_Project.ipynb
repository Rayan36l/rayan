import numpy as np
import matplotlib.pyplot as plt

# Mars Environment Constants
g_mars = -3.71        # m/s^2 [cite: 219]
rho_0 = 0.02          # kg/m^3 (Atmospheric density at surface) 
H_scale = 11100       # Scale height for Mars atmosphere (meters)

# Lander Physical Properties
mass = 2000.0         # kg [cite: 202]
Cd = 1.5              # Drag coefficient [cite: 203]
area = 20.0           # m^2 (Surface area) [cite: 203]
max_thrust = 15000.0  # Newtons [cite: 199]

# Initial Conditions
altitude = 10000.0    # Starting height (meters)
velocity = -50.0      # Starting velocity (m/s)
dt = 0.1              # Time step in seconds [cite: 232]


# Data storage for plotting [cite: 312]
alt_data, vel_data, thrust_data, time_data = [], [], [], []
t = 0.0

while altitude > 0:
    # 1. GNC / Controller Logic 
    # Simple logic: If we are low and falling too fast, fire engines
    if altitude < 750 and velocity < -2.0:
        thrust = max_thrust
    else:
        thrust = 0.0
    
    # 2. Physics Equations [cite: 206, 211]
    # Atmospheric density changes with altitude
    rho = rho_0 * np.exp(-altitude / H_scale)
    
    # Drag Force = 0.5 * rho * v^2 * Cd * A
    drag = 0.5 * rho * (velocity**2) * Cd * area
    if velocity < 0: drag = -drag # Drag opposes falling
        
    total_force = (mass * g_mars) + thrust - drag
    acceleration = total_force / mass
    
    # 3. Euler Integration 
    velocity += acceleration * dt
    altitude += velocity * dt
    t += dt
    
    # Store results
    alt_data.append(altitude)
    vel_data.append(velocity)
    thrust_data.append(thrust)
    time_data.append(t)

print(f"Landing Successful! Final Velocity: {abs(velocity):.2f} m/s")


fig, (ax1, ax2, ax3) = plt.subplots(3, 1, figsize=(8, 12))

# Plot 1: Altitude vs Time (Key Plot) [cite: 312]
ax1.plot(time_data, alt_data, color='blue', linewidth=2)
ax1.set_ylabel("Altitude (m)")
ax1.set_title("Mars Landing Trajectory")
ax1.grid(True)

# Plot 2: Velocity vs Time (Supporting Plot 1) [cite: 313]
ax2.plot(time_data, vel_data, color='red', linewidth=2)
ax2.axhline(y=-2, color='black', linestyle='--', label='Safety Limit')
ax2.set_ylabel("Velocity (m/s)")
ax2.legend()
ax2.grid(True)

# Plot 3: Thrust vs Time (Supporting Plot 2) [cite: 313]
ax3.fill_between(time_data, thrust_data, color='orange', alpha=0.5)
ax3.set_ylabel("Engine Thrust (N)")
ax3.set_xlabel("Time (s)")
ax3.grid(True)

plt.tight_layout()
plt.show()



